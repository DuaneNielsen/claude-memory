{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "test -x \"${CLAUDE_PLUGIN_ROOT}/.venv/bin/python\" || (cd \"${CLAUDE_PLUGIN_ROOT}\" && uv sync --quiet)"
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/memory-check-reset.sh"
          },
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/session_start_index.py\""
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/memory-check.sh"
          }
        ]
      }
    ]
  }
}
